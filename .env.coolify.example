# Copie para .env.coolify e preencha antes do deploy.
# Guia completo: docs/COOLIFY.md (Coolify) e docs/TLS-E-DOMINIO.md (domínio + 80/443).

# ── Domínio público ──
# Coolify: defina o domínio na UI (serviço gateway) + OHIF_VIEWER_URL abaixo.
# VPS standalone (docker-compose.tls.yml): preencha LEX_PACS_DOMAIN + LETSENCRYPT_EMAIL.
# Local: use http://localhost:3000 e docker-compose.coolify.local.yml (sem TLS).
#
# LEX_PACS_DOMAIN=pacs.seudominio.com
# LETSENCRYPT_EMAIL=admin@seudominio.com

# ── URL pública (HTTPS em produção) — único domínio ──
# Deve coincidir com LEX_PACS_DOMAIN quando usar TLS (https:// + mesmo host).
# Se nginx no host faz proxy :80 → gateway:3000, use o domínio SEM :3000
# (ex.: http://meudominio.com, não http://localhost:3000).
OHIF_VIEWER_URL=https://pacs.seudominio.com
COOKIE_SECURE=true

# OIDC interno (rede Docker — NÃO trocar pelo domínio público)
# ORTHANC_URL=http://server:8042
# OIDC_ISSUER_URL=http://auth:8080/auth/realms/lex-pacs

# ── HL7 ORM (integração RIS) ──
HL7_ORM_ENABLED=true
HL7_ORM_PORT=2575
HL7_ORM_AUTO_SYNC=true

OIDC_ENABLED=true
OIDC_CLIENT_ID=lex-clinical
OIDC_CLIENT_SECRET=gere-um-segredo-forte-aqui

# Keycloak (rede interna; hostname público para redirects OIDC)
# KEYCLOAK_PUBLIC_HOSTNAME=pacs.seudominio.com
# KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_PROXY=edge
KEYCLOAK_SSL_REQUIRED=external
KEYCLOAK_HTTP_RELATIVE_PATH=/auth

# ── Segredos obrigatórios ──
PORTAL_JWT_SECRET=gere-minimo-32-caracteres-aleatorios
POSTGRES_PASSWORD=senha-forte-postgres
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=senha-forte-keycloak

# ── Auth clínica ──
# Produção: false (somente Keycloak). Dev: true + bootstrap abaixo
CLINICAL_LOCAL_AUTH_ENABLED=false
CLINICAL_BOOTSTRAP_USER=
CLINICAL_BOOTSTRAP_PASSWORD=

# ── Active Directory (integração via Keycloak; senha da conta de serviço LDAP) ──
# Configure host/DN na aba Integração → Active Directory. A senha fica só no ambiente.
AD_BIND_PASSWORD=

# ── Versão e PostgreSQL ──
LEX_PACS_VERSION=0.7.0
POSTGRES_DB=orthanc
POSTGRES_USER=orthanc

# ── DICOM (modalidades) ──
DICOM_PORT=4242

# ── Portal paciente ──
PORTAL_FALLBACK_CODE=
VIEWER_TOKEN_EXPIRE_MINUTES=30

# ── Backup (status na Admin; job automático requer perfil backup local) ──
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4

# ── Backup remoto (Railway volume ou bucket S3) ──
# Opção A — volume Railway montado no serviço backup (ex.: /railway-backups):
# BACKUP_REMOTE_DIR=/railway-backups
#
# Opção B — bucket S3 (Railway Bucket ou AWS); credenciais do painel Railway:
# BACKUP_S3_BUCKET=seu-bucket
# BACKUP_S3_PREFIX=lex-pacs/producao
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=https://storage.railway.app
# AWS_DEFAULT_REGION=auto

# ── Rate limit login ──
LOGIN_RATE_LIMIT_ATTEMPTS=20
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
