# Copie para .env.coolify e preencha antes do deploy no Coolify.
# Todas as chaves abaixo devem existir no compose (docker-compose.coolify.yml).

# ── URL pública (HTTPS) ──
# Domínio atribuído ao serviço gateway no Coolify
OHIF_VIEWER_URL=https://pacs.seudominio.com
COOKIE_SECURE=true

# Keycloak — domínio público (segundo serviço no Coolify, ex. auth.seudominio.com)
OIDC_PUBLIC_ISSUER_URL=https://auth.seudominio.com/realms/lex-pacs
KEYCLOAK_PUBLIC_URL=https://auth.seudominio.com
KEYCLOAK_PUBLIC_HOSTNAME=auth.seudominio.com
KEYCLOAK_HOSTNAME_STRICT=true
KEYCLOAK_PROXY=edge
KEYCLOAK_SSL_REQUIRED=external

# OIDC interno (rede Docker — não alterar)
OIDC_ISSUER_URL=http://keycloak:8080/realms/lex-pacs
OIDC_ENABLED=true
OIDC_CLIENT_ID=lex-clinical
OIDC_CLIENT_SECRET=gere-um-segredo-forte-aqui

# ── Segredos obrigatórios ──
PORTAL_JWT_SECRET=gere-minimo-32-caracteres-aleatorios
POSTGRES_PASSWORD=senha-forte-postgres
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=senha-forte-keycloak

# ── Auth clínica ──
# Produção: false (somente Keycloak). Dev: true + bootstrap abaixo
CLINICAL_LOCAL_AUTH_ENABLED=false
CLINICAL_BOOTSTRAP_USER=
CLINICAL_BOOTSTRAP_PASSWORD=

# ── Versão e PostgreSQL ──
LEX_PACS_VERSION=0.7.0
POSTGRES_DB=orthanc
POSTGRES_USER=orthanc

# ── DICOM (modalidades) ──
DICOM_PORT=4242

# ── Portal paciente ──
PORTAL_FALLBACK_CODE=
VIEWER_TOKEN_EXPIRE_MINUTES=30

# ── Backup (status na Admin; job automático requer perfil backup local) ──
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4

# ── Rate limit login ──
LOGIN_RATE_LIMIT_ATTEMPTS=20
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
