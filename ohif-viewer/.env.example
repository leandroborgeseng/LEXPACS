# Portal do paciente
PORTAL_JWT_SECRET=altere-este-segredo-com-minimo-32-caracteres-aleatorios
PORTAL_FALLBACK_CODE=
VIEWER_TOKEN_EXPIRE_MINUTES=30
COOKIE_SECURE=false

# URL pública do sistema (mesma porta do gateway)
OHIF_VIEWER_URL=http://localhost:3000

# Acesso clínico (worklist em /viewer/)
# Gerar credenciais: ./scripts/generate-htpasswd.sh [usuario] [senha]
# Arquivo gerado: nginx/.htpasswd (não versionar em produção)

# Produção: use docker-compose.prod.yml e defina COOKIE_SECURE=true com HTTPS

# Versão do produto (tags lex-pacs/viewer e lex-pacs/portal)
LEX_PACS_VERSION=0.7.0

# PostgreSQL (índice Orthanc — E3)
POSTGRES_DB=orthanc
POSTGRES_USER=orthanc
POSTGRES_PASSWORD=altere-esta-senha-postgres-em-producao

# OIDC clínico (E14 / Onda D) — Keycloak em desenvolvimento
OIDC_ENABLED=true
OIDC_ISSUER_URL=http://keycloak:8080/auth/realms/lex-pacs
OIDC_PUBLIC_ISSUER_URL=http://localhost:3000/auth/realms/lex-pacs
OIDC_CLIENT_ID=lex-clinical
OIDC_CLIENT_SECRET=lex-clinical-dev-secret
# Dev: htpasswd local como fallback. Produção: false (só Keycloak)
CLINICAL_LOCAL_AUTH_ENABLED=true
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Backup automático (Onda C / E5) — perfil opcional: docker compose --profile backup up -d backup
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_DAYS=14

# Rate limit login (S10) — complementa nginx
LOGIN_RATE_LIMIT_ATTEMPTS=20
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
